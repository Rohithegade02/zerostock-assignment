# ============================================================
# Dependencies
# ============================================================
**/node_modules/
**/.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# ============================================================
# Build outputs
# ============================================================
**/dist/
**/build/
**/out/
**/.next/

# ============================================================
# Environment variables
# ============================================================
**/.env
**/.env.*
# Allow example env files
!**/.env.example

# ============================================================
# Testing & coverage
# ============================================================
**/coverage/

# ============================================================
# Logs
# ============================================================
*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# ============================================================
# TypeScript
# ============================================================
**/*.tsbuildinfo
search-focused/frontend/next-env.d.ts

# ============================================================
# Misc
# ============================================================
**/.DS_Store
**/*.pem
**/.vercel
